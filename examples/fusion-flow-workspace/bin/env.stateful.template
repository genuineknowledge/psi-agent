# Fusion Flow 子 agent「常驻活会话」接入配置（模板）
#
# 这是部署侧准备文件。真实生效的是你运行 `npx tsx` 的目录（workDir）下的 .env
# （bundle 用 dotenv 从 CWD 加载，见 SKILL.md）。把本模板按实际绝对路径填好后，
# 复制成 <workDir>/.env 即可启用常驻会话子 agent。
#
# 原理：FLOW_PSI_COMMAND 指向 bin/session_shim.py，劫持 bundle 的「一次性 psi-agent run」
#       为「连常驻 psi-agent session」，让同一子 agent 跨多轮保持记忆。
#
# 为什么必须走 shim：当前 psi-agent CLI 的 `run` 子命令是 YAML 批量启动器
#       （只收一个位置参数 config 路径），不再接受 bundle 拼的
#       `run --workspace --message --profile ...`。裸调会 tyro 报 exit=2
#       “Missing value for argument 'config'”。shim 把这套老式调用翻译成新三层架构
#       （ai --provider + session + channel cli），所以 FLOW_PSI_COMMAND 必须接上它。

FLOW_ENGINE=psi
FLOW_PSI_WORKSPACE=/ABS/PATH/TO/executor-workspace

# —— 常驻会话接入（核心）——
# FLOW_PSI_COMMAND 必须是单个可执行；shim 路径放进 ARGS。
#
# POSIX（macOS / Linux）：
FLOW_PSI_COMMAND=python3
FLOW_PSI_COMMAND_ARGS=/ABS/PATH/TO/fusion-flow-workspace/bin/session_shim.py
#
# Windows：python3 常不存在，用 python；路径用正斜杠或双反斜杠，别用单反斜杠。
#   FLOW_PSI_COMMAND=python
#   FLOW_PSI_COMMAND_ARGS=C:/ABS/PATH/TO/fusion-flow-workspace/bin/session_shim.py

# shim 内部起 psi-agent（session / channel cli / ai backend）用的命令前缀。
# 默认 "uv run --no-sync psi-agent" 只在 psi-agent 仓库工作树内有效；
# 若 psi-agent 已全局安装，直接设为 "psi-agent"。
PSI_CMD=uv run --no-sync psi-agent
# 全局安装场景：PSI_CMD=psi-agent

# 本 run 的进程/socket 登记目录；flow 结束后用 bin/session_cleanup.py 据此回收。
# POSIX：
FUSION_SHIM_STATE_DIR=/tmp/fusion-shim-run
# Windows（无 /tmp，用用户临时目录）：
#   FUSION_SHIM_STATE_DIR=C:/Users/<you>/AppData/Local/Temp/fusion-shim-run

# —— AI backend（shim 起共享 backend 时用；若已有现成 backend 用 FLOW_PSI_AI_SOCKET 复用）——
FLOW_PSI_MODEL=deepseek-v4-pro
# FLOW_PSI_API_KEY=...
# FLOW_PSI_BASE_URL=https://api.deepseek.com
# FLOW_PSI_AI_SOCKET=/ABS/PATH/TO/existing-ai.sock
# any-llm provider 名（main 新架构：ai --provider <name>）。
# OpenAI 兼容上游（火山/deepseek 等）填 openai，并用 FLOW_PSI_BASE_URL 指向其端点。
FLOW_PSI_AI=openai
