# Fusion Flow 子 agent「常驻活会话」接入配置（模板）
#
# 这是部署侧准备文件。真实生效的是 skills/fusion-flow/.env（被 .gitignore，需手动放）。
# 把本模板内容按实际绝对路径填好后，复制到 skills/fusion-flow/.env 即可启用常驻会话子 agent。
#
# 原理：FLOW_PSI_COMMAND 指向 bin/session_shim.py，劫持 bundle 的「一次性 psi-agent run」
#       为「连常驻 psi-agent session」，让同一子 agent 跨多轮保持记忆。
# 见 OpenProse docs/stateful-session-plan.html。

FLOW_ENGINE=psi
FLOW_PSI_WORKSPACE=/ABS/PATH/TO/executor-workspace
FLOW_PSI_PROFILE=fusion

# —— 常驻会话接入（核心）——
# FLOW_PSI_COMMAND 必须是单个可执行；shim 路径放进 ARGS。
FLOW_PSI_COMMAND=python3
FLOW_PSI_COMMAND_ARGS=/ABS/PATH/TO/fusion-flow-workspace/bin/session_shim.py

# shim 内部起 psi-agent（session / channel cli / ai backend）用的命令前缀。
PSI_CMD=uv run --no-sync psi-agent

# 本 run 的进程/socket 登记目录；flow 结束后用 bin/session_cleanup.py 据此回收。
FUSION_SHIM_STATE_DIR=/tmp/fusion-shim-run

# —— AI backend（shim 起共享 backend 时用；若已有现成 backend 用 FLOW_PSI_AI_SOCKET 复用）——
FLOW_PSI_MODEL=deepseek-v4-pro
# FLOW_PSI_API_KEY=...
# FLOW_PSI_BASE_URL=https://api.deepseek.com
# FLOW_PSI_AI_SOCKET=/ABS/PATH/TO/existing-ai.sock
FLOW_PSI_AI=openai-completions
