# Copy values from the iFLYTEK console into the Gateway process environment.
# Do not commit a real .env.xfyun file.

XFYUN_STT_APP_ID=your_stt_app_id
XFYUN_STT_API_KEY=your_stt_api_key
XFYUN_STT_API_SECRET=your_stt_api_secret

XFYUN_TTS_APP_ID=your_tts_app_id
XFYUN_TTS_API_KEY=your_tts_api_key
XFYUN_TTS_API_SECRET=your_tts_api_secret
