# =============================================================================
# MCP Server Configuration for haitun-workspace
# =============================================================================
# Copy this file to .env and fill in your values.
# WARNING: .env is gitignored — never commit secrets!

# ---------------------------------------------------------------------------
# PW — Playwright Browser Automation (MCP)
# ---------------------------------------------------------------------------
# Already works! npx auto-downloads @playwright/mcp on first use.
# If you installed it locally, use the local path instead:
MCP_PW_CONFIG={"command":"npx","args":["@playwright/mcp"]}

# ---------------------------------------------------------------------------
# FEISHU — Feishu/Lark Messaging
# ---------------------------------------------------------------------------

# --- Option A: Webhook mode (simplest, recommended) ---
# 1. Open any Feishu group → Settings → Group Bot → Custom Bot
# 2. Copy the webhook URL and paste it below:
FEISHU_WEBHOOK_URL=

# --- Option B: Full API mode (cards, images, files) ---
# Uncomment and fill in if you need advanced features:
# MCP_FEISHU_CONFIG={"command":"python","args":["mcp_servers/feishu_server.py"]}
# FEISHU_APP_ID=cli_xxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxx

# ---------------------------------------------------------------------------
# MEDIA — Image Generation, Vision, TTS, STT (MCP)
# ---------------------------------------------------------------------------
# Uncomment and fill in if you need media capabilities:
# MCP_MEDIA_CONFIG={"command":"python","args":["mcp_servers/media_server.py"]}
# OPENAI_API_KEY=sk-xxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1   # optional: for compatible APIs
