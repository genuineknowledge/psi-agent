# Nginx: public OpenAI-compatible entry → BigModel (key injected server-side).
# Installed by scripts/install-nginx-ai.sh (placeholders replaced).
#
# Client:  POST https://haitun.addchess.cn/chat/completions
# Upstream: POST https://open.bigmodel.cn/api/paas/v4/chat/completions

limit_req_zone $binary_remote_addr zone=haitun_ai_limit:10m rate=30r/m;

server {
    listen 80;
    server_name haitun.addchess.cn;

    limit_req zone=haitun_ai_limit burst=10 nodelay;

    # Generated by install/reload scripts — contains proxy_set_header Authorization ...
    include /etc/nginx/haitun-ai-secret.conf;

    location / {
        proxy_pass https://open.bigmodel.cn/api/paas/v4/;
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_set_header Host open.bigmodel.cn;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Drop client Bearer (placeholder); secret include sets the real one.
        proxy_set_header Authorization $haitun_ai_authorization;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }
}
